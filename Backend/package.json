{
  "name": "backend",
  "version": "1.0.0",
  "description": "MERN project backend with AWS Lambda and Express",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "invoke": "serverless invoke local --function app",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:test": "serverless deploy --stage test",
    "deploy:prod": "serverless deploy --stage prod",
    "remove:dev": "serverless remove --stage dev",
    "remove:test": "serverless remove --stage test",
    "remove:prod": "serverless remove --stage prod"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express4": "^1.1.2",
    "@aws-sdk/client-dynamodb": "^3.1079.0",
    "@aws-sdk/lib-dynamodb": "^3.1079.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.3",
    "graphql": "^16.14.2",
    "ioredis": "^5.11.1",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "serverless": "^3.40.0"
  }
}
